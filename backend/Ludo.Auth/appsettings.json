{
  "AllowedHosts": "*",
  "CorsConfiguration": {
    "Origins": [
      "http://localhost:5000",
      "http://localhost:5005",
      "http://localhost:5009"
    ]
  },
  "JwtConfiguration": {
    "Key": "SecretKey00000000000000000000000",
    "Issuer": "https://my.app",
    "Audience": "https://my.app"
  },
  "FileStorageConfiguration": {
    "_comment": "This path is where the file service saves the files on the filesystem.",
    "SavePath": "../TempDocuments"
  },
  "MailConfiguration": { 
    "_comment": "This configures the mail service. Set MailEnable to true for testing. MailHost this is the host for mail trap, you can setup an account on https://mailtrap.io/ and use it to test mails.",
    "MailEnable": false,
    "MailHost": "sandbox.smtp.mailtrap.io",
    "MailPort": 2525,
    "MailAddress": "test@my.app",
    "MailUser": "",
    "MailPassword": ""
  },
  "DatabaseConfiguration": {
    "EnableAutomaticMigrations": true
  },
  "ClientConfiguration": {
    "_comment": "Hope this configuration works",
    "BaseAddress": "http://localhost:5009"
  }
}
